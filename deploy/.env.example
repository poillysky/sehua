# 复制为 .env 后修改。勿提交含真实密码的 .env。

# GitHub 用户名或组织名（镜像前缀 ghcr.io/<GHCR_OWNER>/sehuatang-*）
GHCR_OWNER=你的GitHub用户名

# 镜像标签
IMAGE_TAG=latest

# 数据根目录（建议 NAS 绝对路径，例如 /vol1/1000/Docker/sehuatang/data）
# 其下子目录：
#   postgres/      PostgreSQL 数据
#   backend/       爬虫 cookies、预览图、可选 auth.sqlite
#   search/        next-web：p115-config.json（115 Cookie）
#   search-cache/  next-web：.next/cache（可选）
DATA_DIR=./data

POSTGRES_USER=postgres
POSTGRES_PASSWORD=请改成强密码
POSTGRES_DB=ed2k
POSTGRES_PUBLISH_PORT=5433

BACKEND_PORT=8080
ADMIN_PORT=8081
SEARCH_PORT=3008

AUTH_REQUIRED=true
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=请改成强密码

# 分端口访问管理端时填写，逗号分隔，例如:
# CORS_ORIGINS=http://192.168.2.38:8081
CORS_ORIGINS=

# 爬虫出网代理（按需）
# WEB_CRAWLER_PROXY=http://192.168.2.88:7893
WEB_CRAWLER_PROXY=

SEARCH_FRONTEND_URL=http://192.168.2.38:3008

# 搜索端翻译（可选）
TRANSLATE_API_URL=
TRANSLATE_FALLBACK=1
